{
  "name": "batchimager",
  "version": "1.0.0",
  "description": "Desktop workspace for batch AI product image generation.",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1 --port 15173 --strictPort\" \"tsc -p tsconfig.node.json --watch\" \"wait-on http://127.0.0.1:15173 dist-electron/main.js && electron .\"",
    "kdev": "node scripts/kill-port.mjs 15173 && npm run dev",
    "build": "tsc -p tsconfig.node.json && vite build",
    "eval:esse": "vitest run electron/services/esseWorkspaceAgentEvaluation.test.ts electron/services/esseWorkspaceRuntime.test.ts electron/services/esseImagePreflightExecutor.test.ts electron/services/essePackagePreflightExecutor.test.ts electron/services/essePreflightBroker.test.ts electron/services/projectUnreferencedFiles.test.ts src/domain/projectWorkspaceAgentEvaluation.test.ts",
    "eval:esse:llm": "node scripts/run-esse-llm-eval.mjs",
    "test": "vitest run",
    "test:e2e": "vitest run src/App.e2e.test.tsx",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "electron:dev": "electron .",
    "package:mac": "node scripts/package-mac-private.mjs",
    "package:mac:x64": "node scripts/package-mac-private.mjs --arch=x64",
    "package:mac:universal": "node scripts/package-mac-private.mjs --arch=universal",
    "package:mac:dir": "npm run build && electron-builder --mac dir"
  },
  "keywords": [
    "electron",
    "image",
    "productivity"
  ],
  "author": "",
  "license": "UNLICENSED",
  "type": "commonjs",
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.75.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "typebox": "1.1.38"
  },
  "build": {
    "appId": "com.batchimager.desktop",
    "productName": "BatchImager",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "src/assets/**/*"
    ],
    "asar": true,
    "extraResources": [
      {
        "from": "resources/built-in-skills",
        "to": "built-in-skills"
      }
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "icon": "src/assets/app-icons/batchimager.icns",
      "identity": null,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "src/assets/app-icons/batchimager-windows.ico"
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "wait-on": "^9.0.10"
  }
}
